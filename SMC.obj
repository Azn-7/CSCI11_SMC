 101 | 30AB | START           LEA R1, NUM_STACK   ;   ADD NULL-TERMINATE VALUE TO NUM_STACK\r\n
 102 | 30AC |                 AND R0, R0, #0\r\n
 103 | 30AD |                 STR R0, R1, #4\r\n
 104 | 30AE |                 LD  R4, STACK       ;   ASSIGN MAIN STACK\r\n
