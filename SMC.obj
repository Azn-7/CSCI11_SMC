 108 | 30B2 |                 PUTS\r\n
 109 | ???? |                 \r\n
 110 | 30B3 | PRE_INPUT       LD R0, _PROMPT_NEXT\r\n
 111 | 30B4 |                 OUT\r\n
 112 | 30B5 | INPUT_LOOP      GETC                ;   GETC & OUT\r\n
 113 | 30B6 |                 JSR OPERATOR_CHK    ;   CHECK FOR OPERATORS\r\n
 114 | 30B7 |                 JSR OTHER_CHAR_CHK  ;   CHECK FOR PERIOD \".\" OR ENTER_KEY\r\n
 115 | 30B8 |                 JSR NUM_CHK         ;   CHECK FOR NUMBERS (0-9)\r\n
 116 | 30B9 |                 BR  INPUT_LOOP      ;   INPUT IS INVALID, REPEATS \r\n
 117 | ???? | \r\n
 118 | ???? | ; ================================================================================\r\n
 119 | ???? | ; ================               NUMBER INPUT                     ================\r\n
 120 | ???? | ; ================================================================================\r\n
 121 | ???? | ; R0 = CURRENT VALUE\r\n
 122 | ???? | ; R1 = (FREE)\r\n
 123 | ???? | ; R2 = (FREE)\r\n
 124 | ???? | ; R3 = NUM_SIZE (For Stage 3a)\r\n
 125 | ???? | ; R4 = NUM_STACK\r\n
 126 | ???? | \r\n
 127 | ???? | ;   -= 1. INITALIZATION =-\r\n
 128 | 30BA | START_NUM       ST  R4, SAVE_R4\r\n
 129 | 30BB |                 LEA R4, NUM_STACK\r\n
 130 | 30BC |                 AND R1, R1, #0\r\n
 131 | 30BD |                 ST  R1, NUM_SIZE    ;   RESET DIGIT COUNTER\r\n
 132 | ???? | \r\n
 133 | ???? | ;   -= 2. LOOP =-\r\n
 134 | 30BE | IS_NUM          OUT\r\n
 135 | 30BF |                 LD  R1, CHAR_TO_DECIMAL\r\n
 136 | 30C0 |                 ADD R0, R0, R1       ;   CONVERT ASCII TO DECIMAL\r\n
 137 | 30C1 |                 STR R0, R4, #0       ;   STORE DIGIT\r\n
 138 | 30C2 |                 ADD R4, R4, #1\r\n
 139 | 30C3 |                 LD  R1, NUM_SIZE     ;   NUM_SIZE++\r\n
 140 | 30C4 |                 ADD R1, R1, #1\r\n
 141 | 30C5 |                 ST  R1, NUM_SIZE     ;   SAVE\r\n
 142 | 30C6 |                 ADD R1, R1, #-4\r\n
 143 | 30C7 |                 BRz USER_DONE        ;   FORCE DONE AT 4 DIGITS\r\n
 144 | 30C8 | REPEAT          GETC\r\n
 145 | 30C9 |                 JSR VALID_CHAR_CHK   ;   CHECK FOR SPACE or OPERATORS (Quick end)\r\n
 146 | 30CA |                 JSR INVALID_NUM_CHK  ;   CHECK FOR ANOTHER DIGIT\r\n
 147 | 30CB |                 BR  IS_NUM\r\n
 148 | ???? | \r\n
 149 | ???? | ;   -= 3. FINISH =-\r\n
 150 | 30CC | USER_DONE       LD  R0, _SPACE      ;   Auto inputs a space to prevent user from typing more than 4 digits\r\n
 151 | 30CD |                 OUT\r\n
 152 | 30CE |                 JSR NUM_COMPUTE\r\n
 153 | 30CF |                 LD  R4, SAVE_R4     ;   Restore Main Stack\r\n
 154 | 30D0 |                 JSR PUSH\r\n
 155 | 30D1 |                 BR  INPUT_LOOP\r\n
 156 | ???? |   \r\n
 157 | ???? | ;   -= 3a. COMPUTING STAGE =-\r\n
 158 | ???? | \r\n
 159 | 30D2 | NUM_COMPUTE     ST  R7, SAVE_R7     ;   For PUSH\r\n
 160 | 30D3 |                 LEA R4, NUM_STACK   ;   Return pointer back to begining of digit\r\n
 161 | 30D4 |                 AND R1, R1, #0      ;   R1 = Result\r\n
 162 | 30D5 |                 LD  R3, NUM_SIZE\r\n
 163 | 30D6 | NUM_LOOP        ADD R3, R3, #0\r\n
 164 | 30D7 |                 BRz NUM_DONE\r\n
 165 | 30D8 |                 LDR R0, R4, #0      ;   R0 = next decimal digit\r\n
 166 | 30D9 |                 ADD R4, R4, #1\r\n
 167 | 30DA |                 ADD R3, R3, #-1\r\n
 168 | 30DB |                 TRAP x28            ;   MULT_10\r\n
 169 | 30DC |                 ADD R1, R1, R0      ;   ADD TOGETHER (Ex. 1 + 10 + 100 + 1000)\r\n
 170 | 30DD |                 BR  NUM_LOOP\r\n
 171 | 30DE | NUM_DONE        ADD R0, R1, #0      ;   PUSH uses R0\r\n
 172 | 30DF |                 RET\r\n
 173 | ???? | \r\n
 174 | ???? | ;   -= FUNCTION CHECKS =-\r\n
 175 | ???? | \r\n
 176 | 30E0 | INVALID_NUM_CHK  LD  R1, _NINE       ;   R0 = \'9\'\r\n
 177 | 30E1 |                 NOT R1, R1\r\n
 178 | 30E2 |                 ADD R1, R1, #1\r\n
